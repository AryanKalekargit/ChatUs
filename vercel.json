{
    "builds": [
        {
            "src": "*.php",
            "use": "vercel-php@0.6.2",
            "config": {
                "includeFiles": "**"
            }
        },
        {
            "src": "admin/*.php",
            "use": "vercel-php@0.6.2",
            "config": {
                "includeFiles": "**"
            }
        },
        {
            "src": "controllers/*.php",
            "use": "vercel-php@0.6.2",
            "config": {
                "includeFiles": "**"
            }
        },
        {
            "src": "assets/**",
            "use": "@vercel/static"
        }
    ],
    "crons": [
        {
            "path": "/keep_alive.php",
            "schedule": "0 12 */3 * *"
        }
    ]
}